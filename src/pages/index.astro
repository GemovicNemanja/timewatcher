---
import TimeWatcherApp from "../components/TimeWatcherApp";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Describe the watch you want. TimeWatcher finds four considered matches and makes their trade-offs easy to understand."
    />
    <meta name="theme-color" content="#f6f4f0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
    <title>TimeWatcher — find a watch that feels right</title>
  </head>
  <body>
    <a class="skip-link" href="#search">Skip to search</a>
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="TimeWatcher home">
        <svg aria-hidden="true" viewBox="0 0 32 32" width="28" height="28">
          <circle cx="16" cy="16" r="11" fill="none" stroke="currentColor" stroke-width="2"></circle>
          <path d="M12 2h8l1 4H11l1-4Zm0 28h8l1-4H11l1 4Z" fill="currentColor"></path>
          <path d="M16 9v7l5 3" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2"></path>
        </svg>
        <span>TimeWatcher</span>
      </a>
      <span class="header-note">Four considered answers, not forty filters.</span>
    </header>
    <main>
      <TimeWatcherApp client:load />
    </main>
    <footer class="site-footer">
      <p>Prices are indicative USD retail and pre-owned ranges. Verify with a seller before buying.</p>
    </footer>
  </body>
</html>
