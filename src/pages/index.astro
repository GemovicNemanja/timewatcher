---
import TimeWatcherApp from "../components/TimeWatcherApp";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Describe the watch you want. TimeWatcher finds four considered matches and makes their trade-offs easy to understand."
    />
    <meta name="theme-color" content="#f6f4f0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,500;1,400&display=swap"
      rel="stylesheet"
    />
    <title>TimeWatcher — find a watch that feels right</title>
  </head>
  <body>
    <a class="skip-link" href="#search">Skip to search</a>
    <main>
      <TimeWatcherApp client:load />
    </main>
  </body>
</html>
